---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** og:type — 'website' for hubs, 'article' for lessons. */
  ogType?: string;
}
const { title, description, ogType = 'website' } = Astro.props;
const year = 2026;
const SITE_NAME = 'Biochemistry-pedia';
const DEFAULT_DESC =
  'An interactive biochemistry textbook — live 3D molecules, original simulations, and the history behind the science. From the Deppmann Lab.';
const desc = description ?? DEFAULT_DESC;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL('/og.png', Astro.site).href : '/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <header class="site-header">
      <nav class="wrap">
        <a href="/" class="brand">
          <span class="brand-mark">⬡</span>
          <span class="brand-name">Biochemistry-pedia</span>
        </a>
        <span class="brand-tag">an interactive biochemistry textbook</span>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p>
          <strong>Biochemistry-pedia</strong> — an interactive biochemistry textbook,
          an <a href="/about">AI&nbsp;Catalyst</a> project by the
          Deppmann Lab.
        </p>
        <p class="fine">
          Code: MIT. Lesson narrative & scientist profiles are drawn from
          <em>The Molecule Hunters</em> and Prof. Deppmann's lectures (authors'
          IP — see <a href="https://github.com/deppmann/biochempedia/blob/main/NOTICE">NOTICE</a>).
          Structures are loaded live from RCSB&nbsp;PDB (CC0) and PubChem.
          Simulations from PhET (CC&nbsp;BY&nbsp;4.0). &copy; {year}.
        </p>
        <p class="fine disclaimer">
          <strong>A note on the figures.</strong> Many of the lecture slides here use
          AI-assisted imagery, so there may be occasional &ldquo;slop&rdquo; artifacts —
          a bond drawn wrong, a structure oriented oddly. Take the slides as a conceptual
          framework, not a reference for memorizing structures; the live 3D molecules in
          each lesson&rsquo;s sidebar are the accurate source. We flag issues as we catch
          them, and this is an evolving project. Spot a correction? See the
          <a href="/contact">contact page</a> or email
          <a href="mailto:deppmann@gmail.com">deppmann@gmail.com</a> and we&rsquo;ll get
          it fixed.
        </p>
        <!-- SEAM: the shared deppmann-brand footer partial (student-credit +
             inspiration-credit lines) replaces this block once Handoff 0 ships. -->
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--ddp-color-line);
        background: color-mix(in srgb, var(--ddp-color-surface) 88%, transparent);
        backdrop-filter: blur(6px);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .site-header nav {
        display: flex;
        align-items: baseline;
        gap: var(--ddp-space-4);
        padding-top: var(--ddp-space-4);
        padding-bottom: var(--ddp-space-4);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--ddp-color-primary);
        font-family: var(--ddp-font-serif);
        font-weight: 700;
        font-size: var(--ddp-text-lg);
      }
      .brand-mark {
        color: var(--ddp-color-accent);
        font-size: 1.2em;
      }
      .brand-tag {
        color: var(--ddp-color-muted);
        font-size: var(--ddp-text-sm);
      }
      @media (max-width: 560px) {
        .brand-tag {
          display: none;
        }
      }
      .site-footer {
        margin-top: var(--ddp-space-16);
        border-top: 1px solid var(--ddp-color-line);
        padding: var(--ddp-space-8) 0 var(--ddp-space-12);
        color: var(--ddp-color-ink-soft);
        font-size: var(--ddp-text-sm);
      }
      .site-footer .fine {
        color: var(--ddp-color-muted);
        font-size: var(--ddp-text-xs);
      }
      .site-footer .disclaimer {
        margin-top: var(--ddp-space-4);
        padding-top: var(--ddp-space-4);
        border-top: 1px solid var(--ddp-color-line);
        max-width: 80ch;
        line-height: 1.6;
      }
      .site-footer .disclaimer a {
        color: var(--ddp-color-accent);
      }
    </style>
  </body>
</html>
