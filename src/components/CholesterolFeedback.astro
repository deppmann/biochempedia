---
/**
 * CholesterolFeedback — the regulation companion to the cholesterol-synthesis step map. The
 * PathwayExplorer walks acetyl-CoA to sterol; this island runs the feedback loop around the
 * committed enzyme, HMG-CoA reductase. Slide the cell's cholesterol and toggle a statin, and watch
 * the SREBP sensor, the enzyme, the LDL receptors, and blood LDL respond — including the
 * counterintuitive payoff: a statin lowers blood cholesterol mostly by making the cell put MORE
 * LDL receptors on its surface, not just by blocking synthesis. Vanilla-TS Astro island. Original.
 */
---

<figure class="chf card" data-cholfb>
  <figcaption class="chf-head">The cholesterol thermostat — SREBP and the statin<span class="chf-chip">⚙ original · interactive</span></figcaption>

  <label class="chf-slabel">Cholesterol reaching the cell (diet + uptake) <em data-out="chol">moderate</em>
    <input type="range" data-in="chol" min="0" max="100" step="5" value="70" />
  </label>

  <label class="chf-toggle"><input type="checkbox" data-in="statin" /> Statin (blocks HMG-CoA reductase)</label>

  <div class="chf-states">
    <div class="chf-state" data-s-srebp><span class="chf-s-name">SREBP sensor</span><span class="chf-s-v" data-srebp></span></div>
    <div class="chf-state" data-s-enz><span class="chf-s-name">HMG-CoA reductase</span><span class="chf-s-v" data-enz></span></div>
    <div class="chf-state" data-s-ldlr><span class="chf-s-name">LDL receptors on surface</span><span class="chf-s-v" data-ldlr></span></div>
    <div class="chf-state" data-s-blood><span class="chf-s-name">Blood LDL</span><span class="chf-s-v" data-blood></span></div>
  </div>
  <p class="chf-why" data-why></p>

  <p class="chf-foot">HMG-CoA reductase is the committed, rate-limiting step, so the cell guards it four ways — transcription (SREBP), enzyme degradation, phosphorylation by AMPK, and the statin's competitive block. The clinical twist lives in the loop: when a statin starves the cell of cholesterol, the cell believes it is short and floods its surface with LDL receptors. Those receptors pull LDL out of the blood — which is how a synthesis inhibitor ends up lowering the number on your lab report.</p>
</figure>

<script>
  document.querySelectorAll<HTMLElement>('[data-cholfb]').forEach((root) => {
    const cholIn = root.querySelector<HTMLInputElement>('[data-in="chol"]')!;
    const cholOut = root.querySelector<HTMLElement>('[data-out="chol"]')!;
    const statinIn = root.querySelector<HTMLInputElement>('[data-in="statin"]')!;
    const srebp = root.querySelector<HTMLElement>('[data-srebp]')!;
    const enz = root.querySelector<HTMLElement>('[data-enz]')!;
    const ldlr = root.querySelector<HTMLElement>('[data-ldlr]')!;
    const blood = root.querySelector<HTMLElement>('[data-blood]')!;
    const sSrebp = root.querySelector<HTMLElement>('[data-s-srebp]')!;
    const sEnz = root.querySelector<HTMLElement>('[data-s-enz]')!;
    const sLdlr = root.querySelector<HTMLElement>('[data-s-ldlr]')!;
    const sBlood = root.querySelector<HTMLElement>('[data-s-blood]')!;
    const why = root.querySelector<HTMLElement>('[data-why]')!;
    function set(elm: HTMLElement, good: boolean) { elm.classList.toggle('is-on', good); elm.classList.toggle('is-off', !good); }
    function render() {
      const chol = parseInt(cholIn.value, 10);
      const statin = statinIn.checked;
      // a statin blocks synthesis, so the cell ends up with less sterol than its supply suggests
      const effSterol = statin ? Math.max(0, chol - 45) : chol;
      cholOut.textContent = chol > 66 ? 'high' : chol > 33 ? 'moderate' : 'low';
      const srebpActive = effSterol < 50;
      srebp.textContent = srebpActive ? 'ACTIVE → nucleus' : 'inactive (held in ER)';
      // enzyme: transcription up when SREBP active; statin blocks catalysis regardless
      enz.textContent = statin ? 'protein up, but BLOCKED by statin' : (srebpActive ? 'high (synthesis ON)' : 'low (synthesis off)');
      ldlr.textContent = srebpActive ? 'HIGH' : 'low';
      blood.textContent = srebpActive ? 'falling ↓' : 'rising ↑';
      // sEnz lit only when the enzyme is actually producing sterol (SREBP on AND not statin-blocked)
      set(sEnz, srebpActive && !statin);
      set(sSrebp, srebpActive);
      set(sLdlr, srebpActive);
      set(sBlood, srebpActive);
      why.textContent = statin
        ? 'Statin on: synthesis is blocked, so the cell runs short of cholesterol even with supply coming in. SREBP activates, the cell carpets its surface with LDL receptors, and they vacuum LDL out of the blood — blood LDL falls. The receptor surge, not the blocked enzyme alone, is the real cholesterol-lowering mechanism.'
        : srebpActive
          ? 'Cell cholesterol is low: SREBP travels to the nucleus and switches on both HMG-CoA reductase (make more) and the LDL receptor (import more). The cell refills its cholesterol, and blood LDL drops as receptors clear it.'
          : 'Cell cholesterol is high: SREBP stays clamped in the ER, the reductase is shut down and degraded, and LDL receptors are sparse. With few receptors clearing it, blood LDL drifts up — the state a high-cholesterol diet pushes you toward.';
    }
    cholIn.addEventListener('input', render);
    statinIn.addEventListener('change', render);
    render();
  });
</script>

<style>
  .chf { padding: var(--ddp-space-3) var(--ddp-space-4) var(--ddp-space-4); margin: var(--ddp-space-5) 0; }
  .chf-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.3rem; font-weight: 600; font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); margin-bottom: var(--ddp-space-2); }
  .chf-chip { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs); font-weight: 400; color: var(--ddp-color-muted); }
  .chf-slabel { display: flex; flex-direction: column; gap: 0.1rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); margin-bottom: var(--ddp-space-2); }
  .chf-slabel em { font-style: normal; font-weight: 700; color: var(--ddp-color-accent); font-family: var(--ddp-font-mono); }
  .chf-slabel input { accent-color: var(--ddp-color-accent); }
  .chf-toggle { display: flex; align-items: center; gap: 0.4rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); margin-bottom: var(--ddp-space-3); cursor: pointer; }
  .chf-toggle input { accent-color: var(--ddp-color-accent); }
  .chf-states { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--ddp-space-2); margin-bottom: var(--ddp-space-3); }
  @media (min-width: 620px) { .chf-states { grid-template-columns: repeat(4, 1fr); } }
  .chf-state { border: 1px solid var(--ddp-color-line); border-left: 3px solid var(--ddp-color-muted); border-radius: 6px; padding: var(--ddp-space-2) var(--ddp-space-3); display: flex; flex-direction: column; gap: 0.15rem; }
  .chf-state.is-on { border-left-color: var(--ddp-color-accent); background: color-mix(in srgb, var(--ddp-color-accent) 10%, #fff); }
  .chf-state.is-off { opacity: 0.62; }
  .chf-s-name { font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); }
  .chf-s-v { font-size: var(--ddp-text-sm); font-weight: 700; color: var(--ddp-color-primary); }
  .chf-why { margin: 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); line-height: 1.5; min-height: 4em; padding: var(--ddp-space-2) var(--ddp-space-3); background: color-mix(in srgb, var(--ddp-color-accent) 8%, transparent); border-radius: 6px; }
  .chf-foot { margin: var(--ddp-space-3) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); border-left: 3px solid var(--ddp-color-secondary); padding-left: 0.55rem; }
</style>
