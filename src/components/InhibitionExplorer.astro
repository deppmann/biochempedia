---
/**
 * InhibitionExplorer — the companion to the Michaelis–Menten plotter. Pick an
 * inhibitor type (competitive, noncompetitive, uncompetitive) and dial [I]/Ki,
 * and watch BOTH the v-vs-[S] hyperbola and the Lineweaver–Burk double-reciprocal
 * plot respond, so the diagnostic signatures become obvious: competitive lines
 * pivot on the y-axis (Vmax unchanged, Km↑), noncompetitive lines pivot on the
 * x-axis (Km unchanged, Vmax↓), uncompetitive lines stay parallel (both ↓).
 * Self-contained vanilla-TS Astro island, no deps. Original, computed live.
 */
---

<figure class="inh card" data-inhibition>
  <figcaption class="inh-head">Enzyme inhibition — two views<span class="inh-chip">⚙ original · interactive</span></figcaption>

  <div class="inh-controls" role="group" aria-label="Inhibitor type">
    <button type="button" data-type="none" aria-pressed="true">No inhibitor</button>
    <button type="button" data-type="competitive" aria-pressed="false">Competitive</button>
    <button type="button" data-type="noncompetitive" aria-pressed="false">Noncompetitive</button>
    <button type="button" data-type="uncompetitive" aria-pressed="false">Uncompetitive</button>
  </div>

  <label class="inh-slabel">Inhibitor amount [I]/K<sub>i</sub> <em data-i-out>0</em>
    <input type="range" data-in="i" min="0" max="5" step="0.5" value="0" disabled />
  </label>

  <div class="inh-grid">
    <section class="inh-col">
      <svg class="inh-svg" viewBox="0 0 320 230" role="img" aria-label="Reaction velocity versus substrate concentration, with and without inhibitor" data-mm></svg>
      <p class="inh-cap">v vs [S] — the saturation curve</p>
    </section>
    <section class="inh-col">
      <svg class="inh-svg" viewBox="0 0 320 230" role="img" aria-label="Lineweaver–Burk double-reciprocal plot, 1/v versus 1/[S]" data-lb></svg>
      <p class="inh-cap">Lineweaver–Burk — 1/v vs 1/[S]</p>
    </section>
  </div>

  <dl class="inh-readout">
    <div><dt>Apparent K<sub>m</sub></dt><dd data-r-km>2.0</dd></div>
    <div><dt>Apparent V<sub>max</sub></dt><dd data-r-vmax>100</dd></div>
  </dl>
  <p class="inh-why" data-why>No inhibitor: the baseline curve. Add one and watch which intercept moves.</p>

  <p class="inh-foot">The double-reciprocal plot turns each inhibitor into a straight-line fingerprint: where the lines cross tells you the mechanism.</p>
</figure>

<script>
  const NS = 'http://www.w3.org/2000/svg';
  const ACCENT = '#0e7c86', ORANGE = '#e57200', INK = '#4b4b55', FAINT = '#b9b9c2';
  function el(name: string, attrs: Record<string, string | number>): SVGElement {
    const e = document.createElementNS(NS, name);
    for (const k in attrs) e.setAttribute(k, String(attrs[k]));
    return e;
  }
  const KM = 2, VMAX = 100; // baseline (arbitrary units)

  document.querySelectorAll<HTMLElement>('[data-inhibition]').forEach((root) => {
    const mm = root.querySelector<SVGSVGElement>('[data-mm]')!;
    const lb = root.querySelector<SVGSVGElement>('[data-lb]')!;
    const slider = root.querySelector<HTMLInputElement>('[data-in="i"]')!;
    const iOut = root.querySelector<HTMLElement>('[data-i-out]')!;
    const rKm = root.querySelector<HTMLElement>('[data-r-km]')!;
    const rVmax = root.querySelector<HTMLElement>('[data-r-vmax]')!;
    const why = root.querySelector<HTMLElement>('[data-why]')!;
    let type: 'none' | 'competitive' | 'noncompetitive' | 'uncompetitive' = 'none';

    function apparent() {
      const r = parseFloat(slider.value);
      const a = 1 + r; // (1 + [I]/Ki)
      if (type === 'competitive') return { km: KM * a, vmax: VMAX };
      if (type === 'noncompetitive') return { km: KM, vmax: VMAX / a };
      if (type === 'uncompetitive') return { km: KM / a, vmax: VMAX / a };
      return { km: KM, vmax: VMAX };
    }

    // ---- MM panel ----
    const X0 = 44, X1 = 304, Y0 = 18, Y1 = 200, SMAX = 20, VTOP = 110;
    const mx = (s: number) => X0 + (s / SMAX) * (X1 - X0);
    const my = (v: number) => Y1 - (v / VTOP) * (Y1 - Y0);
    function curve(km: number, vmax: number) {
      let d = '';
      for (let s = 0; s <= SMAX; s += 0.4) { const v = (vmax * s) / (km + s); d += (s === 0 ? 'M' : 'L') + mx(s).toFixed(1) + ' ' + my(v).toFixed(1) + ' '; }
      return d.trim();
    }
    function drawMM(km: number, vmax: number) {
      mm.replaceChildren();
      mm.appendChild(el('line', { x1: X0, y1: Y0, x2: X0, y2: Y1, stroke: INK, 'stroke-width': 1 }));
      mm.appendChild(el('line', { x1: X0, y1: Y1, x2: X1, y2: Y1, stroke: INK, 'stroke-width': 1 }));
      const yl = el('text', { x: X0 - 6, y: Y0 + 8, 'text-anchor': 'end', 'font-size': 9, fill: INK }); yl.textContent = 'v'; mm.appendChild(yl);
      const xl = el('text', { x: X1, y: Y1 + 16, 'text-anchor': 'end', 'font-size': 9, fill: INK }); xl.textContent = '[S]'; mm.appendChild(xl);
      // Vmax asymptotes
      mm.appendChild(el('line', { x1: X0, y1: my(VMAX), x2: X1, y2: my(VMAX), stroke: FAINT, 'stroke-width': 1, 'stroke-dasharray': '2 3' }));
      if (type !== 'none' && parseFloat(slider.value) > 0) mm.appendChild(el('line', { x1: X0, y1: my(vmax), x2: X1, y2: my(vmax), stroke: ORANGE, 'stroke-width': 1, 'stroke-dasharray': '2 3', opacity: 0.6 }));
      const vlab = el('text', { x: X1 - 2, y: my(VMAX) - 3, 'text-anchor': 'end', 'font-size': 8, fill: INK }); vlab.textContent = 'Vmax'; mm.appendChild(vlab);
      // baseline (faint) + current
      mm.appendChild(el('path', { d: curve(KM, VMAX), fill: 'none', stroke: FAINT, 'stroke-width': 1.6, 'stroke-dasharray': '4 3' }));
      mm.appendChild(el('path', { d: curve(km, vmax), fill: 'none', stroke: ACCENT, 'stroke-width': 2.6 }));
    }

    // ---- Lineweaver–Burk panel ----
    const LX0 = 52, LX1 = 304, LY0 = 18, LY1 = 200, RXMIN = -0.6, RXMAX = 1.0, RYMAX = 0.16;
    const lx = (x: number) => LX0 + ((x - RXMIN) / (RXMAX - RXMIN)) * (LX1 - LX0);
    const ly = (y: number) => LY1 - (y / RYMAX) * (LY1 - LY0);
    function lbLine(km: number, vmax: number, color: string, w: number, dash?: string) {
      // 1/v = (km/vmax)(1/[S]) + 1/vmax  → y = slope*x + b
      const slope = km / vmax, b = 1 / vmax;
      const a: Record<string, string | number> = { x1: lx(RXMIN), y1: ly(slope * RXMIN + b), x2: lx(RXMAX), y2: ly(slope * RXMAX + b), stroke: color, 'stroke-width': w };
      if (dash) a['stroke-dasharray'] = dash;
      return el('line', a);
    }
    function drawLB(km: number, vmax: number) {
      lb.replaceChildren();
      // axes (x-axis at y=0, y-axis at x=0)
      lb.appendChild(el('line', { x1: lx(0), y1: LY0, x2: lx(0), y2: LY1 + 6, stroke: INK, 'stroke-width': 1 }));
      lb.appendChild(el('line', { x1: LX0, y1: ly(0), x2: LX1, y2: ly(0), stroke: INK, 'stroke-width': 1 }));
      const yl = el('text', { x: lx(0) + 4, y: LY0 + 8, 'font-size': 9, fill: INK }); yl.textContent = '1/v'; lb.appendChild(yl);
      const xl = el('text', { x: LX1, y: ly(0) + 14, 'text-anchor': 'end', 'font-size': 9, fill: INK }); xl.textContent = '1/[S]'; lb.appendChild(xl);
      // baseline (faint) + current
      lb.appendChild(lbLine(KM, VMAX, FAINT, 1.8, '4 3'));
      lb.appendChild(lbLine(km, vmax, ACCENT, 2.6));
      // mark intercepts of current line
      const b = 1 / vmax, xint = -1 / km;
      lb.appendChild(el('circle', { cx: lx(0), cy: ly(b), r: 3, fill: ACCENT }));
      if (xint >= RXMIN) lb.appendChild(el('circle', { cx: lx(xint), cy: ly(0), r: 3, fill: ACCENT }));
    }

    function render() {
      const r = parseFloat(slider.value);
      iOut.textContent = r.toFixed(1);
      const { km, vmax } = apparent();
      drawMM(km, vmax); drawLB(km, vmax);
      rKm.textContent = km.toFixed(1); rVmax.textContent = Math.round(vmax).toString();
      const active = type !== 'none' && r > 0;
      why.textContent = !active
        ? 'No inhibitor: the baseline curve (dashed) and the current curve coincide. Add an inhibitor and watch which intercept moves.'
        : type === 'competitive'
          ? 'Competitive: the inhibitor competes for the active site, so more substrate overcomes it — Vmax is unchanged but apparent Km rises. On the double-reciprocal plot the lines share a y-intercept (1/Vmax) and pivot there.'
        : type === 'noncompetitive'
          ? 'Noncompetitive: the inhibitor binds away from the active site, so substrate cannot outcompete it — Vmax falls while Km is unchanged. The lines share an x-intercept (−1/Km) and pivot there.'
          : 'Uncompetitive: the inhibitor binds only the enzyme–substrate complex, lowering both Vmax and Km by the same factor. The lines stay parallel (same slope), shifted up.';
    }

    root.querySelectorAll<HTMLButtonElement>('[data-type]').forEach((b) =>
      b.addEventListener('click', () => {
        type = b.getAttribute('data-type') as typeof type;
        root.querySelectorAll<HTMLButtonElement>('[data-type]').forEach((x) => x.setAttribute('aria-pressed', String(x === b)));
        slider.disabled = type === 'none';
        if (type === 'none') slider.value = '0';
        else if (parseFloat(slider.value) === 0) slider.value = '2';
        render();
      }));
    slider.addEventListener('input', render);
    render();
  });
</script>

<style>
  .inh { padding: var(--ddp-space-3) var(--ddp-space-4) var(--ddp-space-4); margin: var(--ddp-space-5) 0; }
  .inh-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.3rem; font-weight: 600; font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); margin-bottom: var(--ddp-space-3); }
  .inh-chip { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs); font-weight: 400; color: var(--ddp-color-muted); }
  .inh-controls { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: var(--ddp-space-2); }
  .inh-controls button { font-family: inherit; font-size: var(--ddp-text-xs); border: 1px solid var(--ddp-color-line); background: #fff; color: var(--ddp-color-ink-soft); border-radius: 5px; padding: 0.28rem 0.6rem; cursor: pointer; }
  .inh-controls button:hover { border-color: var(--ddp-color-accent); color: var(--ddp-color-primary); }
  .inh-controls button[aria-pressed='true'] { background: color-mix(in srgb, var(--ddp-color-accent) 14%, #fff); color: var(--ddp-color-primary); font-weight: 700; border-color: var(--ddp-color-accent); }
  .inh-slabel { display: flex; flex-direction: column; gap: 0.1rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); margin-bottom: var(--ddp-space-3); }
  .inh-slabel em { font-style: normal; font-weight: 700; color: var(--ddp-color-accent); font-family: var(--ddp-font-mono); }
  .inh-slabel input { accent-color: var(--ddp-color-accent); }
  .inh-slabel input:disabled { opacity: 0.4; }
  .inh-grid { display: grid; grid-template-columns: 1fr; gap: var(--ddp-space-3); }
  @media (min-width: 640px) { .inh-grid { grid-template-columns: 1fr 1fr; } }
  .inh-svg { width: 100%; height: auto; background: #fff; border: 1px solid var(--ddp-color-line); border-radius: 6px; }
  .inh-cap { margin: var(--ddp-space-1) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); text-align: center; }
  .inh-readout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--ddp-space-2); margin: var(--ddp-space-3) 0 var(--ddp-space-2); padding: var(--ddp-space-2) var(--ddp-space-3); background: color-mix(in srgb, var(--ddp-color-accent) 8%, transparent); border-radius: 6px; }
  .inh-readout div { display: flex; flex-direction: column; gap: 0.1rem; }
  .inh-readout dt { font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); }
  .inh-readout dd { margin: 0; font-family: var(--ddp-font-mono); font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); font-weight: 700; }
  .inh-why { margin: 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); line-height: 1.5; min-height: 3em; }
  .inh-foot { margin: var(--ddp-space-3) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); border-left: 3px solid var(--ddp-color-secondary); padding-left: 0.55rem; }
</style>
