---
import type { LectureSlide } from '../schema';
interface Props {
  slides: LectureSlide[];
}
const { slides } = Astro.props;
---

<section class="deck card" data-deck aria-roledescription="carousel" aria-label="Lecture slides">
  <div class="deck-stage">
    {slides.map((s, i) => (
      <figure class="deck-slide" data-slide={i} hidden={i !== 0}>
        <figcaption class="deck-head">
          <span class="deck-title">{s.title}</span>
          <span class="deck-src">{s.source}</span>
        </figcaption>
        <img
          class="deck-img"
          src={s.src}
          alt={s.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        <div class="deck-foot">
          {s.audio && (
            <div class="deck-audio">
              <span class="deck-audio-label">🔊 Listen</span>
              <audio controls preload="none" src={s.audio}>Audio not supported.</audio>
            </div>
          )}
          <details class="deck-notes" open>
            <summary>Presenter notes</summary>
            <p>{s.notes}</p>
          </details>
        </div>
      </figure>
    ))}
  </div>

  <div class="deck-controls">
    <button type="button" class="deck-btn" data-prev aria-label="Previous slide">←</button>
    <div class="deck-dots" role="tablist">
      {slides.map((s, i) => (
        <button
          type="button"
          class={`deck-dot${i === 0 ? ' is-active' : ''}`}
          data-dot={i}
          title={s.title}
          aria-label={`Go to slide ${i + 1}: ${s.title}`}
        ></button>
      ))}
    </div>
    <span class="deck-counter"><strong data-current>1</strong> / {slides.length}</span>
    <button type="button" class="deck-btn" data-next aria-label="Next slide">→</button>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-deck]').forEach((deck) => {
    const slides = Array.from(deck.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(deck.querySelectorAll<HTMLButtonElement>('[data-dot]'));
    const current = deck.querySelector('[data-current]');
    const total = slides.length;
    let idx = 0;

    function show(next: number) {
      idx = (next + total) % total;
      slides.forEach((s, i) => {
        s.hidden = i !== idx;
        if (i !== idx) {
          const a = s.querySelector('audio');
          if (a) a.pause();
        }
      });
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === idx);
        d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
      if (current) current.textContent = String(idx + 1);
    }

    deck.querySelector('[data-prev]')?.addEventListener('click', () => show(idx - 1));
    deck.querySelector('[data-next]')?.addEventListener('click', () => show(idx + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => show(i)));
    deck.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { show(idx - 1); }
      if (e.key === 'ArrowRight') { show(idx + 1); }
    });
    deck.tabIndex = 0;
  });
</script>

<style>
  .deck {
    overflow: hidden;
  }
  .deck:focus-visible {
    outline: 2px solid var(--ddp-color-accent);
    outline-offset: 2px;
  }
  .deck-head {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ddp-space-2);
    align-items: baseline;
    justify-content: space-between;
    padding: var(--ddp-space-3) var(--ddp-space-4);
    border-bottom: 1px solid var(--ddp-color-line);
  }
  .deck-title {
    font-weight: 600;
    font-family: var(--ddp-font-serif);
    color: var(--ddp-color-primary);
  }
  .deck-src {
    font-family: var(--ddp-font-mono);
    font-size: var(--ddp-text-xs);
    color: var(--ddp-color-muted);
  }
  .deck-img {
    display: block;
    width: 100%;
    max-height: 56vh;
    object-fit: contain;
    background: #fff;
  }
  .deck-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--ddp-space-3);
    padding: var(--ddp-space-3) var(--ddp-space-4);
    border-top: 1px solid var(--ddp-color-line);
  }
  .deck-audio {
    display: flex;
    align-items: center;
    gap: var(--ddp-space-2);
    flex: 1;
    min-width: 240px;
  }
  .deck-audio-label {
    font-size: var(--ddp-text-sm);
    font-weight: 600;
    color: var(--ddp-color-primary);
    white-space: nowrap;
  }
  .deck-audio audio {
    height: 34px;
    flex: 1;
  }
  .deck-notes summary {
    cursor: pointer;
    font-size: var(--ddp-text-sm);
    font-weight: 600;
    color: var(--ddp-color-accent);
  }
  .deck-notes p {
    margin: var(--ddp-space-2) 0 0;
    font-size: var(--ddp-text-sm);
    color: var(--ddp-color-ink-soft);
    max-width: 70ch;
  }
  .deck-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ddp-space-4);
    padding: var(--ddp-space-3) var(--ddp-space-4);
    border-top: 1px solid var(--ddp-color-line);
    background: color-mix(in srgb, var(--ddp-color-accent) 4%, transparent);
  }
  .deck-btn {
    border: 1px solid var(--ddp-color-line);
    background: var(--ddp-color-surface);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--ddp-color-primary);
    line-height: 1;
  }
  .deck-btn:hover {
    border-color: var(--ddp-color-accent);
    color: var(--ddp-color-accent);
  }
  .deck-dots {
    display: flex;
    gap: var(--ddp-space-2);
  }
  .deck-dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border-radius: 50%;
    border: none;
    background: var(--ddp-color-line);
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .deck-dot:hover {
    transform: scale(1.3);
  }
  .deck-dot.is-active {
    background: var(--ddp-color-accent);
  }
  .deck-counter {
    font-family: var(--ddp-font-mono);
    font-size: var(--ddp-text-sm);
    color: var(--ddp-color-muted);
    min-width: 3.5em;
    text-align: center;
  }
  .deck-counter strong {
    color: var(--ddp-color-primary);
  }
</style>
