---
import type { ScientistCard } from '../schema';
interface Props {
  scientist: ScientistCard;
}
const { scientist } = Astro.props;
const initials = scientist.name
  .replace(/&.*/, '')
  .trim()
  .split(/\s+/)
  .map((w) => w[0])
  .slice(0, 2)
  .join('');
---

<details class="sci card">
  <summary class="sci-summary">
    {scientist.photo ? (
      <img class="sci-photo" src={scientist.photo} alt={`Portrait of ${scientist.name}`} loading="lazy" />
    ) : (
      <span class="sci-photo sci-photo--ph" aria-hidden="true">{initials}</span>
    )}
    <div class="sci-head">
      <h3 class="sci-name">{scientist.name}</h3>
      {scientist.dates && <span class="sci-dates">{scientist.dates}</span>}
      <p class="sci-contribution">{scientist.contribution}</p>
    </div>
    <span class="sci-toggle" aria-hidden="true"></span>
  </summary>

  <div class="sci-body">
    {scientist.story && <p class="sci-story">{scientist.story}</p>}

    {scientist.quotes.length > 0 && (
      <ul class="sci-quotes">
        {scientist.quotes.map((q) => (
          <li><blockquote>“{q}”</blockquote></li>
        ))}
      </ul>
    )}

    <p class="sci-source">
      <span class="verified-chip">✓ verbatim</span>
      {scientist.profileSourceAnchor}
    </p>
  </div>
</details>

<style>
  .sci {
    padding: 0;
    overflow: hidden;
    height: fit-content;
  }
  .sci-summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--ddp-space-4);
    padding: var(--ddp-space-4);
    cursor: pointer;
    list-style: none;
  }
  .sci-summary::-webkit-details-marker {
    display: none;
  }
  .sci-summary:hover {
    background: color-mix(in srgb, var(--ddp-color-accent) 5%, transparent);
  }
  .sci-photo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--ddp-color-bg-alt, #f0ede7);
    border: 2px solid var(--ddp-color-line);
    flex: none;
  }
  .sci-photo--ph {
    display: grid;
    place-items: center;
    font-family: var(--ddp-font-serif);
    font-weight: 700;
    color: var(--ddp-color-muted);
  }
  .sci-head {
    min-width: 0;
  }
  .sci-name {
    margin: 0;
    font-size: var(--ddp-text-base);
    line-height: 1.2;
  }
  .sci-dates {
    font-family: var(--ddp-font-mono);
    font-size: var(--ddp-text-xs);
    color: var(--ddp-color-muted);
  }
  .sci-contribution {
    margin: var(--ddp-space-1) 0 0;
    color: var(--ddp-color-ink-soft);
    font-size: var(--ddp-text-sm);
  }
  .sci-toggle {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid var(--ddp-color-line);
    position: relative;
    flex: none;
    transition: transform 0.2s, border-color 0.2s;
  }
  .sci-toggle::before,
  .sci-toggle::after {
    content: '';
    position: absolute;
    background: var(--ddp-color-accent);
    inset: 50% 5px auto 5px;
    height: 2px;
    transform: translateY(-50%);
  }
  .sci-toggle::after {
    transform: translateY(-50%) rotate(90deg);
    transition: transform 0.2s;
  }
  details[open] .sci-toggle::after {
    transform: translateY(-50%) rotate(0deg);
  }
  details[open] .sci-toggle {
    border-color: var(--ddp-color-accent);
  }
  .sci-body {
    padding: 0 var(--ddp-space-4) var(--ddp-space-5);
    border-top: 1px dashed var(--ddp-color-line);
    margin-top: 0;
    animation: sci-reveal 0.25s ease;
  }
  @keyframes sci-reveal {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: none; }
  }
  .sci-story {
    margin: var(--ddp-space-4) 0 0;
    font-size: var(--ddp-text-sm);
    line-height: 1.6;
    color: var(--ddp-color-ink);
  }
  .sci-quotes {
    list-style: none;
    padding: 0;
    margin: var(--ddp-space-4) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--ddp-space-3);
  }
  .sci-quotes blockquote {
    margin: 0;
    padding: 0 0 0 var(--ddp-space-4);
    border-left: 3px solid var(--ddp-color-accent);
    font-family: var(--ddp-font-serif);
    font-style: italic;
    color: var(--ddp-color-ink);
    font-size: var(--ddp-text-base);
  }
  .sci-source {
    margin: var(--ddp-space-4) 0 0;
    font-size: var(--ddp-text-xs);
    color: var(--ddp-color-muted);
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-wrap: wrap;
  }
</style>
