---
/**
 * A small, fun topic icon for a lesson card on the home grid.
 * Engraving style: navy single-weight linework (currentColor) with gold accents
 * (brand --ddp-color-secondary), matching the "Quiet Authority" splash design.
 *
 * Keyed by lesson slug. Unknown slugs fall back to a generic orbital "molecule"
 * mark so every chapter renders an icon until it earns its own — add a new
 * `slug === '…'` branch (or, later, a frontmatter `icon` field) per lesson.
 */
interface Props {
  slug: string;
  size?: number;
}
const { slug, size = 46 } = Astro.props;
---

{slug === 'enzyme-kinetics' ? (
  <svg
    viewBox="0 0 56 56"
    width={size}
    height={size}
    role="img"
    aria-label="Michaelis–Menten saturation curve approaching Vmax"
    style="color:var(--ddp-color-primary)"
  >
    <line x1="14" y1="15" x2="50" y2="15" style="stroke:var(--ddp-color-secondary)" stroke-width="1.3" />
    <g fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 47 V9 M12 47 H50" />
      <path d="M12 45 Q25 15 50 15.5" />
      <path d="M18.5 31 q3.2 -3.6 6.4 0" />
      <line x1="21.7" y1="24" x2="21.7" y2="28.6" />
    </g>
    <circle cx="21.7" cy="22" r="3" style="fill:var(--ddp-color-secondary)" />
  </svg>
) : slug === 'amino-acids' ? (
  <svg
    viewBox="0 0 56 56"
    width={size}
    height={size}
    role="img"
    aria-label="An amino acid: a central carbon bonded to four groups, with its variable side chain highlighted"
    style="color:var(--ddp-color-primary)"
  >
    <line x1="28" y1="28" x2="45" y2="28" style="stroke:var(--ddp-color-secondary)" stroke-width="1.75" stroke-linecap="round" />
    <g fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <line x1="28" y1="28" x2="28" y2="12" />
      <line x1="28" y1="28" x2="12" y2="28" />
      <line x1="28" y1="28" x2="28" y2="44" />
      <circle cx="28" cy="28" r="3.2" />
      <circle cx="28" cy="9" r="3" />
      <circle cx="9" cy="28" r="3" />
      <circle cx="28" cy="47" r="2.2" />
    </g>
    <circle cx="48" cy="28" r="3.4" style="fill:var(--ddp-color-secondary)" />
  </svg>
) : slug === 'glycolysis' ? (
  <svg
    viewBox="0 0 56 56"
    width={size}
    height={size}
    role="img"
    aria-label="Glycolysis: a glucose ring split into two pyruvate, releasing ATP"
    style="color:var(--ddp-color-primary)"
  >
    <g fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="35,12 31.5,18 24.5,18 21,12 24.5,6 31.5,6" />
      <path d="M28 18 V30" />
      <path d="M28 30 L20.5 43 M28 30 L35.5 43" />
      <circle cx="20" cy="45.5" r="2.4" />
      <circle cx="36" cy="45.5" r="2.4" />
    </g>
    <path d="M45 21 l1.4 4 4 1.4 -4 1.4 -1.4 4 -1.4 -4 -4 -1.4 4 -1.4 z" style="fill:var(--ddp-color-secondary)" />
  </svg>
) : slug === 'protein-3d-structure' ? (
  <svg
    viewBox="0 0 56 56"
    width={size}
    height={size}
    role="img"
    aria-label="An alpha-helix coil, the basic repeating shape of protein secondary structure"
    style="color:var(--ddp-color-primary)"
  >
    <g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M28 9 C15 15 15 23 28 29 C41 35 41 43 28 49" />
    </g>
    <circle cx="28" cy="9" r="3.2" style="fill:var(--ddp-color-secondary)" />
  </svg>
) : (
  <svg
    viewBox="0 0 48 48"
    width={size}
    height={size}
    role="img"
    aria-label="Molecule"
    style="color:var(--ddp-color-primary)"
  >
    <g fill="none" stroke="currentColor" stroke-width="1.6">
      <ellipse cx="24" cy="24" rx="19" ry="6.5" />
      <ellipse cx="24" cy="24" rx="19" ry="6.5" transform="rotate(60 24 24)" />
      <ellipse cx="24" cy="24" rx="19" ry="6.5" transform="rotate(120 24 24)" />
      <circle cx="24" cy="24" r="4.5" />
    </g>
    <circle cx="24" cy="24" r="2.4" style="fill:var(--ddp-color-secondary)" />
  </svg>
)}
