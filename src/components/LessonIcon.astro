---
/**
 * A small, fun topic icon for a lesson card on the home grid.
 * Engraving style: navy single-weight linework (currentColor) with gold accents
 * (brand --ddp-color-secondary), matching the "Quiet Authority" splash design.
 *
 * Keyed by lesson slug. Unknown slugs fall back to a generic orbital "molecule"
 * mark so every chapter renders an icon until it earns its own — add a new
 * `slug === '…'` branch (or, later, a frontmatter `icon` field) per lesson.
 */
interface Props {
  slug: string;
  size?: number;
}
const { slug, size = 46 } = Astro.props;
---

{slug === 'enzyme-kinetics' ? (
  <svg
    viewBox="0 0 56 56"
    width={size}
    height={size}
    role="img"
    aria-label="Michaelis–Menten saturation curve approaching Vmax"
    style="color:var(--ddp-color-primary)"
  >
    <line x1="14" y1="15" x2="50" y2="15" style="stroke:var(--ddp-color-secondary)" stroke-width="1.3" />
    <g fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 47 V9 M12 47 H50" />
      <path d="M12 45 Q25 15 50 15.5" />
      <path d="M18.5 31 q3.2 -3.6 6.4 0" />
      <line x1="21.7" y1="24" x2="21.7" y2="28.6" />
    </g>
    <circle cx="21.7" cy="22" r="3" style="fill:var(--ddp-color-secondary)" />
  </svg>
) : (
  <svg
    viewBox="0 0 48 48"
    width={size}
    height={size}
    role="img"
    aria-label="Molecule"
    style="color:var(--ddp-color-primary)"
  >
    <g fill="none" stroke="currentColor" stroke-width="1.6">
      <ellipse cx="24" cy="24" rx="19" ry="6.5" />
      <ellipse cx="24" cy="24" rx="19" ry="6.5" transform="rotate(60 24 24)" />
      <ellipse cx="24" cy="24" rx="19" ry="6.5" transform="rotate(120 24 24)" />
      <circle cx="24" cy="24" r="4.5" />
    </g>
    <circle cx="24" cy="24" r="2.4" style="fill:var(--ddp-color-secondary)" />
  </svg>
)}
