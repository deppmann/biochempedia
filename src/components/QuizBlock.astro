---
import type { Question } from '../schema';

interface Props {
  practice: Question[];
  mcat: Question[];
}
const { practice, mcat } = Astro.props;

// One ordered sequence for the stepper; MCAT items keep their badge.
const items = [
  ...practice.map((q) => ({ q, badge: null as string | null })),
  ...mcat.map((q) => ({ q, badge: 'MCAT-style · original' })),
];
const letters = ['A', 'B', 'C', 'D', 'E', 'F'];
---

<section class="quiz card" data-quiz aria-label="Self-test">
  <div class="quiz-top">
    <span class="quiz-progress">Question <strong data-qnum>1</strong> of {items.length}</span>
    <span class="quiz-score">Score <strong data-correct>0</strong> / <span data-answered>0</span></span>
  </div>
  <div class="quiz-bar"><span class="quiz-bar-fill" data-bar></span></div>

  <div class="quiz-stage">
    {items.map((it, i) => (
      <article class="q" data-question data-answer={it.q.answer} hidden={i !== 0}>
        {it.badge && <span class="quiz-badge">{it.badge}</span>}
        <p class="q-stem">{it.q.stem}</p>
        <ul class="q-choices">
          {it.q.choices.map((choice, ci) => (
            <li>
              <button type="button" class="q-choice" data-idx={ci} aria-pressed="false">
                <span class="q-letter">{letters[ci]}</span>
                <span>{choice}</span>
              </button>
            </li>
          ))}
        </ul>
        <div class="q-feedback" hidden>
          <p class="q-verdict" data-verdict></p>
          <p class="q-rationale"><strong>Why:</strong> {it.q.rationale}</p>
        </div>
      </article>
    ))}
  </div>

  <div class="quiz-nav">
    <button type="button" class="quiz-navbtn" data-prev>← Prev</button>
    <button type="button" class="quiz-reset" data-reset>Reset</button>
    <button type="button" class="quiz-navbtn" data-next>Next →</button>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-quiz]').forEach((root) => {
    const questions = Array.from(root.querySelectorAll<HTMLElement>('[data-question]'));
    const total = questions.length;
    const qnum = root.querySelector('[data-qnum]');
    const correctEl = root.querySelector('[data-correct]');
    const answeredEl = root.querySelector('[data-answered]');
    const bar = root.querySelector<HTMLElement>('[data-bar]');
    const answered = new Set<HTMLElement>();
    let correct = 0;
    let idx = 0;

    function refresh() {
      if (qnum) qnum.textContent = String(idx + 1);
      if (correctEl) correctEl.textContent = String(correct);
      if (answeredEl) answeredEl.textContent = String(answered.size);
      if (bar) bar.style.width = `${((idx + 1) / total) * 100}%`;
    }
    function show(next: number) {
      idx = Math.max(0, Math.min(total - 1, next));
      questions.forEach((q, i) => (q.hidden = i !== idx));
      refresh();
    }

    questions.forEach((q) => {
      const answer = Number(q.getAttribute('data-answer'));
      const choices = Array.from(q.querySelectorAll<HTMLButtonElement>('.q-choice'));
      const feedback = q.querySelector<HTMLElement>('.q-feedback')!;
      const verdict = q.querySelector<HTMLElement>('[data-verdict]')!;
      choices.forEach((btn) => {
        btn.addEventListener('click', () => {
          const pick = Number(btn.getAttribute('data-idx'));
          const firstTry = !answered.has(q);
          choices.forEach((b) => {
            const bi = Number(b.getAttribute('data-idx'));
            b.classList.remove('is-correct', 'is-wrong', 'is-chosen');
            if (bi === answer) b.classList.add('is-correct');
            if (bi === pick && pick !== answer) b.classList.add('is-wrong');
            b.setAttribute('aria-pressed', bi === pick ? 'true' : 'false');
          });
          const right = pick === answer;
          verdict.textContent = right ? '✓ Correct' : '✗ Not quite';
          verdict.className = 'q-verdict ' + (right ? 'is-correct' : 'is-wrong');
          feedback.hidden = false;
          if (firstTry) {
            answered.add(q);
            if (right) correct++;
            refresh();
          }
        });
      });
    });

    root.querySelector('[data-prev]')?.addEventListener('click', () => show(idx - 1));
    root.querySelector('[data-next]')?.addEventListener('click', () => show(idx + 1));
    root.querySelector('[data-reset]')?.addEventListener('click', () => {
      correct = 0;
      answered.clear();
      questions.forEach((q) => {
        q.querySelectorAll('.q-choice').forEach((b) => {
          b.classList.remove('is-correct', 'is-wrong', 'is-chosen');
          b.setAttribute('aria-pressed', 'false');
        });
        const fb = q.querySelector<HTMLElement>('.q-feedback');
        if (fb) fb.hidden = true;
      });
      show(0);
    });

    refresh();
  });
</script>

<style>
  .quiz {
    padding: var(--ddp-space-5);
  }
  .quiz-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--ddp-font-mono);
    font-size: var(--ddp-text-sm);
    color: var(--ddp-color-ink-soft);
  }
  .quiz-top strong {
    color: var(--ddp-color-primary);
  }
  .quiz-score strong {
    color: var(--ddp-color-verified);
  }
  .quiz-bar {
    height: 4px;
    border-radius: 2px;
    background: var(--ddp-color-line);
    margin: var(--ddp-space-3) 0 var(--ddp-space-5);
    overflow: hidden;
  }
  .quiz-bar-fill {
    display: block;
    height: 100%;
    width: 12.5%;
    background: var(--ddp-color-accent);
    transition: width 0.25s ease;
  }
  .quiz-badge {
    display: inline-block;
    font-size: var(--ddp-text-xs);
    font-weight: 600;
    color: var(--ddp-color-secondary-ink);
    background: #fdeede;
    border-radius: 999px;
    padding: 0.15em 0.7em;
    margin-bottom: var(--ddp-space-3);
  }
  .q-stem {
    margin: 0 0 var(--ddp-space-4);
    font-size: var(--ddp-text-base);
    min-height: 3em;
  }
  .q-choices {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ddp-space-2);
  }
  .q-choice {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: var(--ddp-space-3);
    text-align: left;
    padding: var(--ddp-space-3) var(--ddp-space-4);
    border: 1px solid var(--ddp-color-line);
    border-radius: var(--ddp-radius-sm);
    background: var(--ddp-color-surface);
    cursor: pointer;
    font-size: var(--ddp-text-sm);
    transition: border-color 0.12s, background 0.12s;
  }
  .q-choice:hover {
    border-color: var(--ddp-color-accent);
  }
  .q-letter {
    font-family: var(--ddp-font-mono);
    font-weight: 700;
    color: var(--ddp-color-muted);
    flex: none;
  }
  .q-choice.is-correct {
    border-color: var(--ddp-color-verified);
    background: var(--ddp-color-verified-soft);
  }
  .q-choice.is-correct .q-letter {
    color: var(--ddp-color-verified);
  }
  .q-choice.is-wrong {
    border-color: #c0392b;
    background: #fcebe9;
  }
  .q-choice.is-wrong .q-letter {
    color: #c0392b;
  }
  .q-feedback {
    margin-top: var(--ddp-space-4);
    padding-top: var(--ddp-space-3);
    border-top: 1px dashed var(--ddp-color-line);
    font-size: var(--ddp-text-sm);
  }
  .q-verdict {
    margin: 0 0 var(--ddp-space-2);
    font-weight: 700;
  }
  .q-verdict.is-correct { color: var(--ddp-color-verified); }
  .q-verdict.is-wrong { color: #c0392b; }
  .q-rationale {
    margin: 0;
    color: var(--ddp-color-ink-soft);
  }
  .quiz-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ddp-space-3);
    margin-top: var(--ddp-space-5);
    padding-top: var(--ddp-space-4);
    border-top: 1px solid var(--ddp-color-line);
  }
  .quiz-navbtn,
  .quiz-reset {
    border: 1px solid var(--ddp-color-line);
    background: var(--ddp-color-surface);
    border-radius: 999px;
    padding: 0.4rem 1.1rem;
    cursor: pointer;
    font-size: var(--ddp-text-sm);
  }
  .quiz-navbtn:hover {
    border-color: var(--ddp-color-accent);
    color: var(--ddp-color-accent);
  }
  .quiz-reset {
    color: var(--ddp-color-muted);
  }
</style>
