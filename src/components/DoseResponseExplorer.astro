---
/**
 * DoseResponseExplorer — the pharmacology companion to the cascade amplifier. A
 * semilog dose–response curve, response = Emax·[L]ⁿ / (EC50ⁿ + [L]ⁿ), with sliders
 * for efficacy (Emax), potency (EC50), Hill steepness (n), and a competitive
 * antagonist that shifts the curve rightward (apparent EC50 × (1+[B]/K_b)) without
 * lowering the ceiling. It grounds the vocabulary of receptor signaling — potency
 * vs efficacy, full vs partial agonist, surmountable antagonism — that the cascade
 * turns into a cellular response. Self-contained vanilla-TS Astro island. Original.
 */
---

<figure class="dr card" data-doseresponse>
  <figcaption class="dr-head">Dose–response — potency, efficacy, antagonism<span class="dr-chip">⚙ original · interactive</span></figcaption>

  <svg class="dr-svg" viewBox="0 0 340 230" role="img" aria-label="A semilog dose–response curve of response versus log ligand concentration" data-plot></svg>

  <div class="dr-controls">
    <label class="dr-slabel">Efficacy E<sub>max</sub> <em data-out="emax">100</em>%
      <input type="range" data-in="emax" min="20" max="100" step="5" value="100" />
    </label>
    <label class="dr-slabel">Potency (log EC₅₀) <em data-out="ec50">0</em>
      <input type="range" data-in="ec50" min="-2" max="2" step="0.25" value="0" />
    </label>
    <label class="dr-slabel">Hill steepness n <em data-out="hill">1</em>
      <input type="range" data-in="hill" min="1" max="4" step="0.5" value="1" />
    </label>
    <label class="dr-slabel">Competitive antagonist [B]/K<sub>b</sub> <em data-out="ant">0</em>
      <input type="range" data-in="ant" min="0" max="30" step="1" value="0" />
    </label>
  </div>

  <dl class="dr-readout">
    <div><dt>Apparent EC₅₀</dt><dd data-r-ec50>1.0</dd></div>
    <div><dt>Ceiling response</dt><dd data-r-emax>100%</dd></div>
  </dl>
  <p class="dr-why" data-why>The dose that gives half-maximal response is the EC₅₀ — the lower it is, the more potent the drug. Efficacy is how high the curve can reach.</p>

  <p class="dr-foot">Potency (EC₅₀, the curve's horizontal position) and efficacy (Emax, its height) are independent. A competitive antagonist slides the curve right but can be overcome with more agonist; it never lowers the ceiling.</p>
</figure>

<script>
  const NS = 'http://www.w3.org/2000/svg';
  const ACCENT = '#0e7c86', ORANGE = '#e57200', INK = '#4b4b55', FAINT = '#b9b9c2';
  function el(name: string, attrs: Record<string, string | number>): SVGElement {
    const e = document.createElementNS(NS, name);
    for (const k in attrs) e.setAttribute(k, String(attrs[k]));
    return e;
  }
  document.querySelectorAll<HTMLElement>('[data-doseresponse]').forEach((root) => {
    const plot = root.querySelector<SVGSVGElement>('[data-plot]')!;
    const q = (s: string) => root.querySelector<HTMLInputElement>(s)!;
    const emaxIn = q('[data-in="emax"]'), ec50In = q('[data-in="ec50"]'), hillIn = q('[data-in="hill"]'), antIn = q('[data-in="ant"]');
    const o = (s: string) => root.querySelector<HTMLElement>(s)!;
    const emaxOut = o('[data-out="emax"]'), ec50Out = o('[data-out="ec50"]'), hillOut = o('[data-out="hill"]'), antOut = o('[data-out="ant"]');
    const rEc50 = o('[data-r-ec50]'), rEmax = o('[data-r-emax]'), why = o('[data-why]');

    const X0 = 40, X1 = 326, Y0 = 16, Y1 = 196, LMIN = -3, LMAX = 3; // x = log10 dose
    const px = (lx: number) => X0 + ((lx - LMIN) / (LMAX - LMIN)) * (X1 - X0);
    const py = (r: number) => Y1 - (r / 100) * (Y1 - Y0);
    function curve(emax: number, logEc50: number, n: number) {
      let d = '';
      for (let lx = LMIN; lx <= LMAX; lx += 0.1) {
        const dose = Math.pow(10, lx), ec = Math.pow(10, logEc50);
        const r = emax * Math.pow(dose, n) / (Math.pow(ec, n) + Math.pow(dose, n));
        d += (lx === LMIN ? 'M' : 'L') + px(lx).toFixed(1) + ' ' + py(r).toFixed(1) + ' ';
      }
      return d.trim();
    }
    function render() {
      const emax = parseInt(emaxIn.value, 10);
      const baseLog = parseFloat(ec50In.value);
      const n = parseFloat(hillIn.value);
      const ant = parseInt(antIn.value, 10);
      const appLog = baseLog + Math.log10(1 + ant); // competitive shift
      emaxOut.textContent = String(emax);
      ec50Out.textContent = baseLog.toFixed(2);
      hillOut.textContent = n.toFixed(1);
      antOut.textContent = String(ant);
      plot.replaceChildren();
      // axes + gridlines
      plot.appendChild(el('line', { x1: X0, y1: Y0, x2: X0, y2: Y1, stroke: INK, 'stroke-width': 1 }));
      plot.appendChild(el('line', { x1: X0, y1: Y1, x2: X1, y2: Y1, stroke: INK, 'stroke-width': 1 }));
      for (const r of [50, 100]) {
        plot.appendChild(el('line', { x1: X0, y1: py(r), x2: X1, y2: py(r), stroke: FAINT, 'stroke-width': 0.7, 'stroke-dasharray': '2 3' }));
        const t = el('text', { x: X0 - 4, y: py(r) + 3, 'text-anchor': 'end', 'font-size': 8, fill: INK }); t.textContent = r + '%'; plot.appendChild(t);
      }
      for (const lx of [-3, -2, -1, 0, 1, 2, 3]) {
        plot.appendChild(el('line', { x1: px(lx), y1: Y1, x2: px(lx), y2: Y1 + 3, stroke: INK, 'stroke-width': 1 }));
        const t = el('text', { x: px(lx), y: Y1 + 13, 'text-anchor': 'middle', 'font-size': 7.5, fill: INK }); t.textContent = '10' + (lx < 0 ? '⁻' + (-lx) : lx === 0 ? '⁰' : lx); plot.appendChild(t);
      }
      const xl = el('text', { x: (X0 + X1) / 2, y: Y1 + 26, 'text-anchor': 'middle', 'font-size': 9, fill: INK }); xl.textContent = 'log [ligand]'; plot.appendChild(xl);
      const yl = el('text', { x: X0 - 2, y: Y0 - 5, 'text-anchor': 'start', 'font-size': 9, fill: INK }); yl.textContent = 'response'; plot.appendChild(yl);
      // reference (no antagonist, full Emax slider) faint, and current
      plot.appendChild(el('path', { d: curve(emax, baseLog, n), fill: 'none', stroke: FAINT, 'stroke-width': 1.6, 'stroke-dasharray': '4 3' }));
      plot.appendChild(el('path', { d: curve(emax, appLog, n), fill: 'none', stroke: ACCENT, 'stroke-width': 2.6 }));
      // mark EC50 (half of THIS curve's emax) on the current curve
      if (appLog >= LMIN && appLog <= LMAX) {
        plot.appendChild(el('line', { x1: px(appLog), y1: py(emax / 2), x2: px(appLog), y2: Y1, stroke: ORANGE, 'stroke-width': 1.2, 'stroke-dasharray': '3 2' }));
        plot.appendChild(el('circle', { cx: px(appLog), cy: py(emax / 2), r: 4, fill: ORANGE }));
      }
      rEc50.textContent = Math.pow(10, appLog).toPrecision(2);
      rEmax.textContent = emax + '%';
      why.textContent = ant > 0
        ? `The competitive antagonist has slid the EC₅₀ from ${Math.pow(10, baseLog).toPrecision(2)} to ${Math.pow(10, appLog).toPrecision(2)} (×${(1 + ant)}), so it takes more agonist to reach the same response — but the ceiling is unchanged. That is surmountable antagonism.`
        : emax < 100
          ? 'With Emax below 100% this behaves like a partial agonist: it occupies the receptor but cannot drive a full response, no matter the dose.'
          : `EC₅₀ = ${Math.pow(10, baseLog).toPrecision(2)} (the dose for half-maximal response). Lower it and the drug is more potent; raise the ceiling and it is more efficacious. Hill n sets how switch-like the curve is.`;
    }
    [emaxIn, ec50In, hillIn, antIn].forEach((s) => s.addEventListener('input', render));
    render();
  });
</script>

<style>
  .dr { padding: var(--ddp-space-3) var(--ddp-space-4) var(--ddp-space-4); margin: var(--ddp-space-5) 0; }
  .dr-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.3rem; font-weight: 600; font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); margin-bottom: var(--ddp-space-3); }
  .dr-chip { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs); font-weight: 400; color: var(--ddp-color-muted); }
  .dr-svg { width: 100%; height: auto; background: #fff; border: 1px solid var(--ddp-color-line); border-radius: 6px; }
  .dr-controls { display: grid; grid-template-columns: 1fr 1fr; gap: var(--ddp-space-2) var(--ddp-space-4); margin: var(--ddp-space-3) 0 var(--ddp-space-2); }
  .dr-slabel { display: flex; flex-direction: column; gap: 0.1rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); }
  .dr-slabel em { font-style: normal; font-weight: 700; color: var(--ddp-color-accent); font-family: var(--ddp-font-mono); }
  .dr-slabel input { accent-color: var(--ddp-color-accent); }
  .dr-readout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--ddp-space-2); margin: var(--ddp-space-2) 0; padding: var(--ddp-space-2) var(--ddp-space-3); background: color-mix(in srgb, var(--ddp-color-accent) 8%, transparent); border-radius: 6px; }
  .dr-readout div { display: flex; flex-direction: column; gap: 0.1rem; }
  .dr-readout dt { font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); }
  .dr-readout dd { margin: 0; font-family: var(--ddp-font-mono); font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); font-weight: 700; }
  .dr-why { margin: 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); line-height: 1.5; min-height: 3em; }
  .dr-foot { margin: var(--ddp-space-3) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); border-left: 3px solid var(--ddp-color-secondary); padding-left: 0.55rem; }
</style>
