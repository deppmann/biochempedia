---
/**
 * GoutUricAcidExplorer — the clinical payoff of the purine-catabolism tail. Where the nucleotide
 * map ends in "uric acid," this island shows WHY that dead-end matters: humans lost uricase, so
 * uric acid is the final product, and it is barely soluble. Push the purine-load slider (diet and
 * cell turnover) and serum urate climbs; cross ~6.8 mg/dL and it crystallizes — a gout flare. Then
 * flip allopurinol on: it poisons xanthine oxidase, the two XO arrows grey out, urate production
 * falls, and the value drops back under the solubility line. Self-contained vanilla-TS Astro island. Original.
 */
---

<figure class="gout card" data-gout>
  <figcaption class="gout-head">From purine to uric acid — and how allopurinol stops the flare<span class="gout-chip">⚙ original · interactive</span></figcaption>

  <svg class="gout-svg" viewBox="0 0 460 120" role="img" data-svg></svg>

  <div class="gout-controls">
    <label class="gout-slabel">Purine load <em data-out="load">moderate</em>
      <input type="range" data-in="load" min="0" max="100" step="5" value="55" />
    </label>
    <button type="button" data-allo class="gout-toggle" aria-pressed="false">Allopurinol: off</button>
  </div>

  <div class="gout-readout">
    <div class="gout-meter" data-meter role="img" aria-label="serum urate relative to solubility threshold"></div>
    <div class="gout-vals">
      <span class="gout-urate">Serum urate <strong data-urate>7.4</strong> mg/dL</span>
      <span class="gout-thresh">solubility limit ≈ 6.8 mg/dL</span>
    </div>
  </div>

  <p class="gout-state" data-state></p>

  <p class="gout-foot">Uric acid is where purine catabolism dead-ends in us — we lost uricase, the enzyme other mammals use to break it down further, so the poorly soluble acid is the last stop. Gout is simply that acid crossing its solubility line and crystallizing in a joint. Allopurinol, one of Elion and Hitchings's rationally designed purine analogs, is the elegant fix: it is itself oxidized by xanthine oxidase into oxypurinol, which then jams the enzyme shut — fewer urate molecules made, the serum level falls back under the line, and the crystals dissolve.</p>
</figure>

<script>
  const ACCENT = '#0e7c86', NAVY = '#232d4b', ORANGE = '#e57200', FAINT = '#b9b9c2', INK = '#4b4b55';
  const GREEN = '#2e8b57', RED = '#c0392b';
  const SVGNS = 'http://www.w3.org/2000/svg';
  function el(name: string, attrs: Record<string, string | number>): SVGElement {
    const e = document.createElementNS(SVGNS, name);
    for (const k in attrs) e.setAttribute(k, String(attrs[k]));
    return e;
  }

  type Node = { x: number; label: string; sub: string };
  const NODES: Node[] = [
    { x: 18, label: 'AMP', sub: 'adenosine' },
    { x: 125, label: 'inosine', sub: '' },
    { x: 222, label: 'hypoxanthine', sub: '' },
    { x: 330, label: 'xanthine', sub: '' },
    { x: 430, label: 'URIC ACID', sub: 'end product' },
  ];
  // arrows 2 and 3 (index 2,3 by their start node) are the xanthine-oxidase steps
  const XO_ARROWS = [2, 3];

  function drawPathway(svg: SVGElement, allo: boolean) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);
    const y = 52;
    const defs = el('defs', {});
    const mk = (id: string, color: string) => {
      const m = el('marker', { id, markerWidth: 8, markerHeight: 8, refX: 6, refY: 3, orient: 'auto' });
      m.appendChild(el('path', { d: 'M0,0 L6,3 L0,6 Z', fill: color }));
      return m;
    };
    defs.appendChild(mk('gout-ar', INK));
    defs.appendChild(mk('gout-ar-xo', allo ? FAINT : ACCENT));
    svg.appendChild(defs);

    for (let i = 0; i < NODES.length - 1; i++) {
      const isXO = XO_ARROWS.indexOf(i) !== -1;
      const greyed = isXO && allo;
      const color = isXO ? (greyed ? FAINT : ACCENT) : INK;
      const x1 = NODES[i].x + 44, x2 = NODES[i + 1].x - 4;
      svg.appendChild(el('line', { x1, y1: y, x2, y2: y, stroke: color, 'stroke-width': isXO ? 2.4 : 1.6, 'marker-end': greyed ? 'url(#gout-ar-xo)' : (isXO ? 'url(#gout-ar-xo)' : 'url(#gout-ar)') }));
      if (isXO) {
        const lab = el('text', { x: (x1 + x2) / 2, y: y - 8, 'text-anchor': 'middle', fill: greyed ? FAINT : ACCENT, 'font-size': 8.5, 'font-weight': 600 });
        lab.textContent = greyed ? 'XO ✕ blocked' : 'xanthine oxidase';
        svg.appendChild(lab);
      }
    }

    NODES.forEach((n, idx) => {
      const last = idx === NODES.length - 1;
      const fill = last ? (allo ? '#7a8a86' : ORANGE) : '#fff';
      const stroke = last ? (allo ? '#7a8a86' : ORANGE) : NAVY;
      svg.appendChild(el('rect', { x: n.x, y: y - 13, width: 88, height: 26, rx: 6, fill: fill, opacity: last ? 0.16 : 1, stroke: stroke, 'stroke-width': last ? 2 : 1.2 }));
      const t = el('text', { x: n.x + 44, y: y + 1, 'text-anchor': 'middle', fill: last ? (allo ? INK : ORANGE) : NAVY, 'font-size': last ? 10 : 9.5, 'font-weight': last ? 700 : 500 });
      t.textContent = n.label;
      svg.appendChild(t);
      if (n.sub) {
        const s = el('text', { x: n.x + 44, y: y + 24, 'text-anchor': 'middle', fill: FAINT, 'font-size': 7.5 });
        s.textContent = n.sub;
        svg.appendChild(s);
      }
    });

    const cap = el('text', { x: 230, y: 108, 'text-anchor': 'middle', fill: INK, 'font-size': 9 });
    cap.textContent = 'humans lack uricase — uric acid is the dead-end';
    svg.appendChild(cap);
  }

  const THRESHOLD = 6.8;

  function drawMeter(meter: HTMLElement, urate: number) {
    while (meter.firstChild) meter.removeChild(meter.firstChild);
    const max = 11;
    const over = urate > THRESHOLD;
    const fill = document.createElement('div');
    fill.className = 'gout-fill';
    fill.style.width = `${Math.min(100, (urate / max) * 100)}%`;
    fill.style.background = over ? RED : GREEN;
    const line = document.createElement('div');
    line.className = 'gout-line';
    line.style.left = `${(THRESHOLD / max) * 100}%`;
    line.title = 'solubility threshold 6.8 mg/dL';
    meter.appendChild(fill);
    meter.appendChild(line);
  }

  document.querySelectorAll<HTMLElement>('[data-gout]').forEach((root) => {
    const svg = root.querySelector('[data-svg]') as unknown as SVGElement;
    const loadIn = root.querySelector<HTMLInputElement>('[data-in="load"]')!;
    const loadOut = root.querySelector<HTMLElement>('[data-out="load"]')!;
    const alloBtn = root.querySelector<HTMLButtonElement>('[data-allo]')!;
    const meter = root.querySelector<HTMLElement>('[data-meter]')!;
    const urateEl = root.querySelector<HTMLElement>('[data-urate]')!;
    const stateEl = root.querySelector<HTMLElement>('[data-state]')!;
    let allo = false;

    function urateFor(load: number): number {
      // baseline 3.5, climbs with purine load toward ~9.5; allopurinol cuts production ~38%
      const raw = 3.5 + (load / 100) * 6.0;
      return allo ? 3.0 + (raw - 3.0) * 0.62 : raw;
    }

    function render() {
      const load = parseInt(loadIn.value, 10);
      loadOut.textContent = load > 70 ? 'high' : load > 35 ? 'moderate' : load > 5 ? 'low' : 'minimal';
      alloBtn.textContent = `Allopurinol: ${allo ? 'on' : 'off'}`;
      alloBtn.setAttribute('aria-pressed', String(allo));
      alloBtn.classList.toggle('gout-toggle--on', allo);

      const urate = urateFor(load);
      urateEl.textContent = urate.toFixed(1);
      const over = urate > THRESHOLD;
      urateEl.style.color = over ? RED : GREEN;
      drawMeter(meter, urate);
      drawPathway(svg, allo);

      if (over) {
        stateEl.textContent = `Crystals forming — gout flare. At ${urate.toFixed(1)} mg/dL the serum is past uric acid's solubility limit, so monosodium urate falls out of solution as needle-sharp crystals in the joint.`;
        stateEl.className = 'gout-state gout-state--bad';
      } else {
        stateEl.textContent = allo
          ? `Soluble — safe. Allopurinol has throttled xanthine oxidase, so urate production drops and the serum sits at ${urate.toFixed(1)} mg/dL, comfortably under the line. The crystals dissolve.`
          : `Soluble — safe. At ${urate.toFixed(1)} mg/dL the urate stays dissolved, below its solubility limit. No crystals.`;
        stateEl.className = 'gout-state gout-state--ok';
      }
    }

    loadIn.addEventListener('input', render);
    alloBtn.addEventListener('click', () => { allo = !allo; render(); });
    render();
  });
</script>

<style>
  .gout { padding: var(--ddp-space-3) var(--ddp-space-4) var(--ddp-space-4); margin: var(--ddp-space-5) 0; }
  .gout-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.3rem; font-weight: 600; font-size: var(--ddp-text-sm); color: var(--ddp-color-primary); margin-bottom: var(--ddp-space-2); }
  .gout-chip { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs); font-weight: 400; color: var(--ddp-color-muted); }
  .gout-svg { width: 100%; height: auto; display: block; background: color-mix(in srgb, var(--ddp-color-accent) 5%, #fff); border: 1px solid var(--ddp-color-line); border-radius: 8px; margin-bottom: var(--ddp-space-3); }
  .gout-controls { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: var(--ddp-space-3); margin-bottom: var(--ddp-space-3); }
  .gout-slabel { display: flex; flex-direction: column; gap: 0.1rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); flex: 1 1 200px; }
  .gout-slabel em { font-style: normal; font-weight: 700; color: var(--ddp-color-accent); font-family: var(--ddp-font-mono); }
  .gout-slabel input { accent-color: var(--ddp-color-accent); }
  .gout-toggle { font-family: inherit; font-size: var(--ddp-text-xs); border: 1px solid var(--ddp-color-line); background: #fff; color: var(--ddp-color-ink-soft); border-radius: 5px; padding: 0.38rem 0.8rem; cursor: pointer; white-space: nowrap; }
  .gout-toggle:hover { border-color: var(--ddp-color-accent); color: var(--ddp-color-primary); }
  .gout-toggle--on { background: color-mix(in srgb, var(--ddp-color-accent) 14%, #fff); border-color: var(--ddp-color-accent); color: var(--ddp-color-primary); font-weight: 700; }
  .gout-readout { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: var(--ddp-space-3); }
  .gout-meter { position: relative; width: 100%; height: 18px; background: color-mix(in srgb, var(--ddp-color-muted) 18%, #fff); border: 1px solid var(--ddp-color-line); border-radius: 9px; overflow: hidden; }
  .gout-fill { position: absolute; left: 0; top: 0; bottom: 0; border-radius: 9px 0 0 9px; }
  .gout-line { position: absolute; top: -3px; bottom: -3px; width: 2px; background: var(--ddp-color-secondary-ink); }
  .gout-vals { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); }
  .gout-urate strong { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-sm); }
  .gout-thresh { font-family: var(--ddp-font-mono); color: var(--ddp-color-secondary-ink); }
  .gout-state { margin: 0; font-size: var(--ddp-text-xs); line-height: 1.5; min-height: 3.4em; padding: var(--ddp-space-2) var(--ddp-space-3); border-radius: 6px; color: var(--ddp-color-ink-soft); }
  .gout-state--bad { background: color-mix(in srgb, #c0392b 10%, transparent); border-left: 3px solid #c0392b; }
  .gout-state--ok { background: color-mix(in srgb, var(--ddp-color-accent) 8%, transparent); border-left: 3px solid var(--ddp-color-accent); }
  .gout-foot { margin: var(--ddp-space-3) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-ink-soft); border-left: 3px solid var(--ddp-color-secondary); padding-left: 0.55rem; }
</style>
