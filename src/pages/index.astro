---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const lessons = (await getCollection('lessons'))
  .filter((l) => !l.data.draft)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Biochemistry-pedia — an interactive biochemistry textbook"
  description="An interactive, integrity-first biochemistry learning site: live 3D molecules, original simulations, and self-tests, built from Prof. Deppmann's lectures and The Molecule Hunters."
>
  <section class="hero wrap">
    <p class="eyebrow">Biochemistry-pedia · BIOL 3030 · University of Virginia</p>
    <h1>Biochemistry you can rotate, drag, and quiz yourself on.</h1>
    <p class="lede">
      Every structure is loaded live from a public database — nothing is drawn by
      an AI. Every simulation is something you can poke. Every question carries a
      verified answer and an explanation. Built from twenty years of lectures and
      the scientist stories in <em>The Molecule Hunters</em>.
    </p>
  </section>

  <section class="wrap lessons">
    <h2>Lessons</h2>
    {lessons.length === 0 ? (
      <p>No lessons published yet.</p>
    ) : (
      <ul class="lesson-list">
        {lessons.map((l) => (
          <li>
            <a href={`/lessons/${l.data.slug}/`} class="lesson-card card">
              <span class="lc-chapter">{l.data.courseChapter}</span>
              <span class="lc-title">{l.data.title}</span>
              <span class="lc-summary">{l.data.summary}</span>
              <span class="lc-meta">
                {l.data.structures.length} live structures ·
                {' '}{l.data.practiceQuestions.length + l.data.mcatQuestions.length} questions
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <style>
    .hero {
      padding: var(--ddp-space-16) var(--ddp-space-6) var(--ddp-space-8);
    }
    .eyebrow {
      font-family: var(--ddp-font-mono);
      font-size: var(--ddp-text-xs);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ddp-color-accent);
      margin: 0 0 var(--ddp-space-3);
    }
    .hero h1 {
      font-size: var(--ddp-text-3xl);
      max-width: 18ch;
    }
    .lede {
      max-width: 60ch;
      font-size: var(--ddp-text-lg);
      color: var(--ddp-color-ink-soft);
    }
    .lessons {
      padding-bottom: var(--ddp-space-12);
    }
    .lesson-list {
      list-style: none;
      padding: 0;
      margin: var(--ddp-space-6) 0 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--ddp-space-4);
    }
    .lesson-card {
      display: flex;
      flex-direction: column;
      gap: var(--ddp-space-2);
      padding: var(--ddp-space-6);
      text-decoration: none;
      color: inherit;
      transition: transform 0.12s, box-shadow 0.12s;
    }
    .lesson-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(26, 26, 31, 0.1);
      text-decoration: none;
    }
    .lc-chapter {
      font-family: var(--ddp-font-mono);
      font-size: var(--ddp-text-xs);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ddp-color-accent);
    }
    .lc-title {
      font-family: var(--ddp-font-serif);
      font-size: var(--ddp-text-xl);
      color: var(--ddp-color-primary);
      line-height: 1.2;
    }
    .lc-summary {
      color: var(--ddp-color-ink-soft);
      font-size: var(--ddp-text-sm);
    }
    .lc-meta {
      margin-top: auto;
      font-family: var(--ddp-font-mono);
      font-size: var(--ddp-text-xs);
      color: var(--ddp-color-muted);
    }
  </style>
</BaseLayout>
