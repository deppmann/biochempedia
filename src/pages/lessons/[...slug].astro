---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MolViewer from '../../components/MolViewer.astro';
import PhetEmbed from '../../components/PhetEmbed.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import SpotifyEmbed from '../../components/SpotifyEmbed.astro';
import LectureSlides from '../../components/LectureSlides.astro';
import QuizBlock from '../../components/QuizBlock.astro';
import SourcesFooter from '../../components/SourcesFooter.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lesson = entry.data;

const phetSims = lesson.simulations.filter((s) => s.type === 'phet');
const hasQuiz = lesson.practiceQuestions.length > 0 || lesson.mcatQuestions.length > 0;
const qCount = lesson.practiceQuestions.length + lesson.mcatQuestions.length;
const narratedSlides = lesson.lectureSlides.filter((s) => s.audio).length;

// Thumbnail helpers for the rail.
const rcsbThumb = (id: string) => `https://cdn.rcsb.org/images/structures/${id.toLowerCase()}_assembly-1.jpeg`;
const pubchemThumb = (id: string) => `https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/${id}/PNG`;
const ytThumb = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const structId = (s: { source: string; id: string }) => `lb-struct-${s.source}-${s.id}`.replace(/[^a-zA-Z0-9-]/g, '');
---

<BaseLayout title={`${lesson.title} — Biochempedia`} description={lesson.summary}>
  <article id="top">
    <header class="lesson-hero wrap">
      <p class="eyebrow">{lesson.courseChapter}</p>
      <h1>{lesson.title}</h1>
      <p class="summary">{lesson.summary}</p>
    </header>

    {lesson.objectives.length > 0 && (
      <aside class="wrap orient" aria-label="Lesson overview">
        <div class="orient-obj card">
          <h2>What you'll learn</h2>
          <ul>{lesson.objectives.map((o) => <li>{o}</li>)}</ul>
        </div>
        <ul class="orient-meta">
          {lesson.estMinutes && <li><span>⏱</span> ~{lesson.estMinutes} min</li>}
          {lesson.structures.length > 0 && <li><span>🧬</span> {lesson.structures.length} live 3D structures</li>}
          {narratedSlides > 0 && <li><span>🎧</span> {narratedSlides} narrated slides</li>}
          {qCount > 0 && <li><span>📝</span> {qCount} self-test questions</li>}
        </ul>
      </aside>
    )}

    {/* Two-column: reading column + sticky resource rail. */}
    <div class="wrap lesson-layout">
      <main class="lesson-main">
        <div class="prose-col"><Content /></div>

        {lesson.techniques.length > 0 && (
          <section class="tech-panel">
            <h2>How we measure it</h2>
            <div class="tech-grid">
              {lesson.techniques.map((t) => (
                <div class="tech card"><h3>{t.name}</h3><p>{t.blurb}</p></div>
              ))}
            </div>
          </section>
        )}
      </main>

      <aside class="rail" aria-label="Explore — open any resource">
        <p class="rail-title">Explore <span>· tap to open</span></p>

        {lesson.lectureSlides.length > 0 && (
          <div class="rail-group">
            <h3>Lecture slides</h3>
            <button type="button" class="rail-slidepreview" data-open="lb-slides">
              <img src={lesson.lectureSlides[0].src} alt={`Preview: ${lesson.lectureSlides[0].title}`} loading="lazy" />
              <span class="rail-label">Lecture slides <em>{lesson.lectureSlides.length} · narrated · tap to open</em></span>
            </button>
          </div>
        )}

        {lesson.structures.length > 0 && (
          <div class="rail-group">
            <h3>3D molecules</h3>
            {lesson.structures.map((s) => (
              <button type="button" class="rail-thumb" data-open={structId(s)}>
                <img src={s.source === 'rcsb' ? rcsbThumb(s.id) : pubchemThumb(s.id)} alt="" loading="lazy" />
                <span class="rail-label">{s.label.split('—')[0].trim()} <em>{s.source === 'rcsb' ? `PDB ${s.id}` : `CID ${s.id}`} · rotate</em></span>
              </button>
            ))}
          </div>
        )}

        {phetSims.length > 0 && (
          <div class="rail-group">
            <h3>Simulations</h3>
            <p class="rail-note">The Michaelis–Menten plotter is woven into the text above — try the sliders as you read.</p>
            {phetSims.map((s, i) => (
              <button type="button" class="rail-thumb" data-open={`lb-phet-${i}`}>
                <span class="rail-ico" aria-hidden="true">▶</span>
                <span class="rail-label">{s.title} <em>PhET</em></span>
              </button>
            ))}
          </div>
        )}

        {lesson.scientists.length > 0 && (
          <div class="rail-group">
            <h3>The people</h3>
            {lesson.scientists.map((s, i) => (
              <button type="button" class="rail-thumb" data-open={`lb-sci-${i}`}>
                {s.photo
                  ? <img src={s.photo} alt="" loading="lazy" />
                  : <span class="rail-ico" aria-hidden="true">👤</span>}
                <span class="rail-label">{s.name} {s.dates && <em>{s.dates}</em>}</span>
              </button>
            ))}
          </div>
        )}

        {(lesson.videos.length > 0 || lesson.podcast) && (
          <div class="rail-group">
            <h3>Watch &amp; listen</h3>
            {lesson.videos.map((v, i) => (
              <button type="button" class="rail-thumb" data-open={`lb-video-${i}`}>
                <img src={ytThumb(v.youtubeId)} alt="" loading="lazy" />
                <span class="rail-label">{v.title} <em>video</em></span>
              </button>
            ))}
            {lesson.podcast && (
              <button type="button" class="rail-thumb" data-open="lb-podcast">
                <span class="rail-ico" aria-hidden="true">🎧</span>
                <span class="rail-label">{lesson.podcast.title ?? 'Podcast'} <em>listen</em></span>
              </button>
            )}
          </div>
        )}

        {hasQuiz && (
          <div class="rail-group">
            <h3>Test yourself</h3>
            <button type="button" class="rail-thumb" data-open="lb-quiz">
              <span class="rail-ico" aria-hidden="true">📝</span>
              <span class="rail-label">Self-test <em>{qCount} questions</em></span>
            </button>
          </div>
        )}

        <div class="rail-group">
          <h3>Reference</h3>
          <button type="button" class="rail-thumb" data-open="lb-sources">
            <span class="rail-ico" aria-hidden="true">📚</span>
            <span class="rail-label">Sources &amp; Integrity <em>every ID &amp; source</em></span>
          </button>
        </div>
      </aside>
    </div>

    {/* ---- Lightboxes (one per resource; hidden until opened) ---- */}
    {lesson.lectureSlides.length > 0 && (
      <dialog id="lb-slides" class="lightbox">
        <div class="lightbox-head"><span>From the lecture</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><LectureSlides slides={lesson.lectureSlides} /></div>
      </dialog>
    )}

    {lesson.structures.map((s) => (
      <dialog id={structId(s)} class="lightbox">
        <div class="lightbox-head"><span>{s.label}</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><MolViewer source={s.source} id={s.id} label={s.label} caption={s.caption} height={520} /></div>
      </dialog>
    ))}

    {phetSims.map((s, i) => (
      <dialog id={`lb-phet-${i}`} class="lightbox">
        <div class="lightbox-head"><span>{s.title}</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><PhetEmbed url={s.ref} title={s.title} attribution={s.attribution} caption={s.caption} /></div>
      </dialog>
    ))}

    {lesson.scientists.map((s, i) => (
      <dialog id={`lb-sci-${i}`} class="lightbox">
        <div class="lightbox-head"><span>{s.name}</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body">
          <div class="profile">
            {s.photo && <img class="profile-photo" src={s.photo} alt={`Portrait of ${s.name}`} />}
            <div class="profile-text">
              <h3>{s.name} {s.dates && <span class="profile-dates">{s.dates}</span>}</h3>
              <p class="profile-contribution">{s.contribution}</p>
              {s.story && <p class="profile-story">{s.story}</p>}
              {s.quotes.length > 0 && (
                <ul class="profile-quotes">{s.quotes.map((q) => <li><blockquote>“{q}”</blockquote></li>)}</ul>
              )}
              <p class="profile-source"><span class="verified-chip">✓ verbatim</span> {s.profileSourceAnchor}</p>
            </div>
          </div>
        </div>
      </dialog>
    ))}

    {lesson.videos.map((v, i) => (
      <dialog id={`lb-video-${i}`} class="lightbox">
        <div class="lightbox-head"><span>{v.title}</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><YouTubeEmbed youtubeId={v.youtubeId} title={v.title} sourceNote={v.sourceNote} /></div>
      </dialog>
    ))}

    {lesson.podcast && (
      <dialog id="lb-podcast" class="lightbox">
        <div class="lightbox-head"><span>{lesson.podcast.title ?? 'Podcast'}</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><SpotifyEmbed url={lesson.podcast.url} title={lesson.podcast.title} note={lesson.podcast.note} /></div>
      </dialog>
    )}

    {hasQuiz && (
      <dialog id="lb-quiz" class="lightbox">
        <div class="lightbox-head"><span>Test yourself</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
        <div class="lightbox-body"><QuizBlock practice={lesson.practiceQuestions} mcat={lesson.mcatQuestions} /></div>
      </dialog>
    )}

    <dialog id="lb-sources" class="lightbox">
      <div class="lightbox-head"><span>Sources &amp; Integrity</span><button type="button" class="lightbox-close" data-close aria-label="Close">✕</button></div>
      <div class="lightbox-body"><SourcesFooter lesson={lesson} /></div>
    </dialog>

    <a href="#top" class="to-top" aria-label="Back to top">↑ Top</a>
  </article>

  <script>
    // Lightbox: open on rail-thumb click, close on ✕ / backdrop / Esc.
    document.querySelectorAll<HTMLElement>('[data-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const d = document.getElementById(btn.getAttribute('data-open')!) as HTMLDialogElement | null;
        if (!d?.showModal) return;
        d.showModal();
        // Auto-play the visible slide's narration when the slideshow opens
        // (within this click gesture, so the browser allows it). The audio's own
        // controls let the student pause / mute.
        const slideAudio = d.querySelector<HTMLAudioElement>('.deck-slide:not([hidden]) audio');
        if (slideAudio) slideAudio.play().catch(() => {});
        // Nudge lazy viewers (Mol*) now that they're visible + sized.
        requestAnimationFrame(() => {
          window.dispatchEvent(new Event('resize'));
          window.dispatchEvent(new Event('scroll'));
        });
      });
    });
    document.querySelectorAll<HTMLDialogElement>('dialog.lightbox').forEach((d) => {
      d.addEventListener('click', (e) => { if (e.target === d) d.close(); });
      d.querySelector('[data-close]')?.addEventListener('click', () => d.close());
      d.addEventListener('close', () => {
        d.querySelectorAll<HTMLMediaElement>('audio, video').forEach((m) => m.pause());
      });
    });
  </script>

  <style>
    .lesson-hero { padding: var(--ddp-space-12) var(--ddp-space-6) var(--ddp-space-6); }
    .eyebrow {
      font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs);
      letter-spacing: 0.08em; text-transform: uppercase; color: var(--ddp-color-accent);
      margin: 0 0 var(--ddp-space-2);
    }
    .lesson-hero h1 { font-size: var(--ddp-text-3xl); max-width: 20ch; margin-bottom: var(--ddp-space-3); }
    .summary { max-width: 60ch; font-size: var(--ddp-text-lg); color: var(--ddp-color-ink-soft); }

    .orient {
      display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--ddp-space-6);
      margin-bottom: var(--ddp-space-6); align-items: start;
    }
    @media (max-width: 760px) { .orient { grid-template-columns: 1fr; } }
    .orient-obj { padding: var(--ddp-space-5) var(--ddp-space-6); }
    .orient-obj h2 { font-size: var(--ddp-text-lg); margin: 0 0 var(--ddp-space-3); }
    .orient-obj ul { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: var(--ddp-space-2); }
    .orient-obj li { font-size: var(--ddp-text-sm); color: var(--ddp-color-ink-soft); }
    .orient-meta { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--ddp-space-2) var(--ddp-space-4); }
    .orient-meta li { font-size: var(--ddp-text-sm); color: var(--ddp-color-ink-soft); display: inline-flex; align-items: center; gap: 0.4em; }

    /* Two-column layout */
    .lesson-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: var(--ddp-space-8);
      align-items: start;
      padding-top: var(--ddp-space-4);
    }
    @media (max-width: 900px) { .lesson-layout { grid-template-columns: 1fr; } }
    .lesson-main { min-width: 0; }
    .lesson-main h2 { font-size: var(--ddp-text-2xl); }

    .tech-panel { margin-top: var(--ddp-space-12); }
    .tech-grid { display: grid; grid-template-columns: 1fr; gap: var(--ddp-space-3); margin-top: var(--ddp-space-4); }
    .tech { padding: var(--ddp-space-4) var(--ddp-space-5); }
    .tech h3 { margin: 0 0 var(--ddp-space-1); font-size: var(--ddp-text-base); }
    .tech p { margin: 0; font-size: var(--ddp-text-sm); color: var(--ddp-color-ink-soft); }

    /* Sticky resource rail */
    .rail {
      position: sticky;
      top: 84px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: var(--ddp-space-4);
      padding-right: 2px;
    }
    @media (max-width: 900px) {
      .rail { position: static; max-height: none; margin-top: var(--ddp-space-8); }
    }
    .rail-title {
      margin: 0; font-family: var(--ddp-font-mono); font-size: var(--ddp-text-xs);
      letter-spacing: 0.06em; text-transform: uppercase; color: var(--ddp-color-primary);
    }
    .rail-title span { color: var(--ddp-color-muted); }
    .rail-group { display: flex; flex-direction: column; gap: var(--ddp-space-2); }
    .rail-group h3 {
      margin: 0; font-size: var(--ddp-text-xs); text-transform: uppercase;
      letter-spacing: 0.04em; color: var(--ddp-color-muted); font-family: var(--ddp-font-sans);
    }
    .rail-thumb {
      display: flex; align-items: center; gap: var(--ddp-space-3);
      width: 100%; text-align: left; padding: var(--ddp-space-2);
      border: 1px solid var(--ddp-color-line); border-radius: var(--ddp-radius-sm);
      background: var(--ddp-color-surface); cursor: pointer; transition: border-color 0.12s, transform 0.12s, box-shadow 0.12s;
    }
    .rail-thumb:hover { border-color: var(--ddp-color-accent); transform: translateY(-1px); box-shadow: var(--ddp-shadow); }
    .rail-thumb img, .rail-ico {
      width: 46px; height: 46px; flex: none; border-radius: 6px; object-fit: cover;
      background: var(--ddp-color-bg-alt, #f0ede7); border: 1px solid var(--ddp-color-line);
    }
    .rail-ico { display: grid; place-items: center; font-size: 1.2rem; }
    .rail-label {
      display: flex; flex-direction: column; min-width: 0;
      font-size: var(--ddp-text-sm); font-weight: 600; color: var(--ddp-color-ink); line-height: 1.25;
    }
    .rail-label em { font-style: normal; font-weight: 400; font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); }
    .rail-note { margin: 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); line-height: 1.4; }

    /* Lecture-slides rail item: an actual mini slide viewer (preview the slide). */
    .rail-slidepreview {
      display: block; width: 100%; text-align: left; padding: 0; cursor: pointer; overflow: hidden;
      border: 1px solid var(--ddp-color-line); border-radius: var(--ddp-radius-sm);
      background: var(--ddp-color-surface); transition: border-color 0.12s, transform 0.12s, box-shadow 0.12s;
    }
    .rail-slidepreview:hover { border-color: var(--ddp-color-accent); transform: translateY(-1px); box-shadow: var(--ddp-shadow); }
    .rail-slidepreview img { display: block; width: 100%; background: #fff; }
    .rail-slidepreview .rail-label { padding: var(--ddp-space-2) var(--ddp-space-3); }

    /* Lightbox dialog */
    .lightbox {
      border: none; padding: 0; border-radius: var(--ddp-radius);
      width: min(1000px, 94vw); max-width: 94vw; max-height: 92vh; overflow: auto;
      background: var(--ddp-color-surface); box-shadow: 0 24px 70px rgba(20, 22, 30, 0.35);
    }
    .lightbox::backdrop { background: rgba(20, 22, 30, 0.62); backdrop-filter: blur(2px); }
    .lightbox-head {
      position: sticky; top: 0; z-index: 2;
      display: flex; align-items: center; justify-content: space-between;
      padding: var(--ddp-space-3) var(--ddp-space-5);
      border-bottom: 1px solid var(--ddp-color-line);
      background: var(--ddp-color-surface);
      font-family: var(--ddp-font-serif); font-weight: 600; color: var(--ddp-color-primary);
    }
    .lightbox-close {
      border: 1px solid var(--ddp-color-line); background: var(--ddp-color-surface);
      width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 0.9rem;
      color: var(--ddp-color-ink-soft); flex: none;
    }
    .lightbox-close:hover { border-color: var(--ddp-color-accent); color: var(--ddp-color-accent); }
    .lightbox-body { padding: var(--ddp-space-5); }

    /* Scientist profile (inside lightbox) */
    .profile { display: grid; grid-template-columns: 160px 1fr; gap: var(--ddp-space-6); align-items: start; }
    @media (max-width: 600px) { .profile { grid-template-columns: 1fr; } }
    .profile-photo { width: 100%; border-radius: var(--ddp-radius); border: 1px solid var(--ddp-color-line); }
    .profile-text h3 { margin: 0; font-size: var(--ddp-text-xl); }
    .profile-dates { font-family: var(--ddp-font-mono); font-size: var(--ddp-text-sm); color: var(--ddp-color-muted); font-weight: 400; }
    .profile-contribution { margin: var(--ddp-space-2) 0 0; color: var(--ddp-color-ink-soft); }
    .profile-story { margin: var(--ddp-space-4) 0 0; line-height: 1.65; }
    .profile-quotes { list-style: none; padding: 0; margin: var(--ddp-space-4) 0 0; display: flex; flex-direction: column; gap: var(--ddp-space-3); }
    .profile-quotes blockquote {
      margin: 0; padding: 0 0 0 var(--ddp-space-4); border-left: 3px solid var(--ddp-color-accent);
      font-family: var(--ddp-font-serif); font-style: italic; font-size: var(--ddp-text-base);
    }
    .profile-source { margin: var(--ddp-space-4) 0 0; font-size: var(--ddp-text-xs); color: var(--ddp-color-muted); display: flex; gap: 0.5em; align-items: center; flex-wrap: wrap; }

    .to-top {
      position: fixed; right: var(--ddp-space-6); bottom: var(--ddp-space-6); z-index: 40;
      font-size: var(--ddp-text-sm); font-weight: 600; text-decoration: none;
      color: var(--ddp-color-surface); background: var(--ddp-color-primary);
      border-radius: 999px; padding: 0.5em 0.9em; box-shadow: var(--ddp-shadow); opacity: 0.85;
    }
    .to-top:hover { opacity: 1; text-decoration: none; }
  </style>
</BaseLayout>
